.DS_Store
**/.DS_Store
node_modules/
.netlify/
.env
.env.local
deno.lock

# Supabase CLI's local cache (gotrue version pin, last-pulled CLI version
# etc.). Generated on `supabase link` / `supabase start` — machine-local,
# nothing for git to track.
supabase/.temp/

# Generated preview from `npm run import:inspect`. Contains PII
# (national IDs, addresses, phones) from the leadership xlsx — never commit.
db/import-preview.json

# Note: `npm run screenshots` writes PNGs to ~/Desktop/SSAM-Demo-Output/
# by default (override via SSAM_DEMO_OUT_DIR). That folder lives OUTSIDE
# the repo intentionally — generated artifacts shouldn't be versioned.
# The spec files under scripts/screenshots/ ARE versioned so the
# pipeline stays reproducible.
